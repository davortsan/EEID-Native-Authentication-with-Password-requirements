﻿@{
    ViewData["Title"] = "Home";
}

<div class="row justify-content-center">
    <div class="col-lg-8 text-center">
        <h1 class="display-5">Native Authentication Demo</h1>
        <p class="lead">Esta Web App usa ASP.NET Core MVC y ejecuta el flujo de Entra External ID Native Authentication en servidor.</p>
        <p>
            <a class="btn btn-primary me-2" asp-controller="Auth" asp-action="Profile">Open profile</a>
            <a class="btn btn-outline-primary" asp-controller="Auth" asp-action="SignIn">Open sign in</a>
        </p>
    </div>
</div>
