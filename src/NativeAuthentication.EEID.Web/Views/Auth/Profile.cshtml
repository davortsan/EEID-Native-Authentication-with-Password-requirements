@model NativeAuthentication.EEID.Web.Models.Auth.SignedInUserViewModel

@{
    ViewData["Title"] = "Profile";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <h1 class="mb-3">Authenticated session</h1>
        <partial name="_StatusMessage" />

        <dl class="row">
            <dt class="col-sm-4">Display name</dt>
            <dd class="col-sm-8">@Model.DisplayName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Access token expiry</dt>
            <dd class="col-sm-8">@(Model.AccessTokenExpiresAt?.ToString("u") ?? "Unknown")</dd>
        </dl>

        <form asp-action="SignOutUser" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">Sign out</button>
        </form>
    </div>
</div>