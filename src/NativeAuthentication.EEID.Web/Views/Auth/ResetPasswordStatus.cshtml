@{
    ViewData["Title"] = "Reset password status";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <h1 class="mb-3">Reset password status</h1>
        <p class="lead">@ViewBag.Message</p>

        @if (string.Equals((string?)ViewBag.Status, "in_progress", StringComparison.OrdinalIgnoreCase) ||
             string.Equals((string?)ViewBag.Status, "not_started", StringComparison.OrdinalIgnoreCase))
        {
            <a asp-action="ResetPasswordStatus" class="btn btn-primary">Refresh status</a>
        }
        else
        {
            <a asp-action="SignIn" class="btn btn-outline-primary">Back to sign in</a>
        }
    </div>
</div>